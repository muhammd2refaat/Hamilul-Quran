# ─── Application ───────────────────────────────────────────────────────────────
APP_NAME="Solar Asset ERP"
APP_ENV=development          # development | production
DEBUG=true

# ─── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=solar_erp
POSTGRES_PASSWORD=solar_erp_secret
POSTGRES_DB=solar_erp_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://solar_erp:solar_erp_secret@db:5432/solar_erp_db

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
