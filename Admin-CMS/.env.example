# Environment variables for QV Admin Panel

# API Configuration
VITE_API_BASE_URL=https://api.platform.com
VITE_API_TIMEOUT=30000

# Authentication
VITE_SESSION_TIMEOUT=1800000
VITE_REFRESH_TOKEN_INTERVAL=300000

# Feature Flags
VITE_ENABLE_LOGGING=false
VITE_ENABLE_2FA=true
VITE_ENABLE_ANALYTICS=true

# File Upload
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
VITE_ALLOWED_VIDEO_TYPES=video/mp4,video/webm

# Pagination
VITE_DEFAULT_PAGE_SIZE=50
VITE_MAX_PAGE_SIZE=100
